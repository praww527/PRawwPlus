# =============================================================================
# PRaww+ — Environment Variables
# Oracle VPS AMD64 + FreeSWITCH + MongoDB + Firebase
# =============================================================================
# Copy this file to .env on your VPS and fill in every value.
#   cp .env.example .env
#   nano .env
# Never commit .env to git.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Node.js API server listens on (nginx proxies to this)
PORT=3000

NODE_ENV=production

# Set to 1 when behind nginx (required for correct client IP / PayFast checks)
TRUST_PROXY=1

# Public-facing HTTPS domain (no trailing slash)
# This is used for CORS, CSP, cookie domains, and FreeSWITCH config.
APP_URL=https://rtc.praww.co.za

# ── MongoDB ───────────────────────────────────────────────────────────────────

# MongoDB Atlas or self-hosted connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/prawwplus?retryWrites=true&w=majority

# Set to false if your MongoDB deployment does not support multi-document transactions
# (e.g. a standalone replica without a replica set).
MONGODB_USE_TRANSACTIONS=true

# ── Firebase (push notifications + FCM) ──────────────────────────────────────
# From your Firebase project → Project Settings → Service Accounts → Generate new private key

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Paste the entire private key including -----BEGIN/END----- lines.
# In .env, wrap in double quotes and use \n for newlines:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── FreeSWITCH ───────────────────────────────────────────────────────────────

# PUBLIC IP of the FreeSWITCH / VPS server.
# Used in verto.conf and sofia profile for ext-rtp-ip / ext-sip-ip so that
# FreeSWITCH advertises the correct IP in ICE candidates and SDP.
# Without the correct public IP, calls connect but have NO AUDIO (one-way or silent).
# Set to your Oracle VPS public IP (e.g. 140.245.xx.xx)
FREESWITCH_DOMAIN=YOUR_VPS_PUBLIC_IP

# ESL (Event Socket Layer) — for API control.
# Always 127.0.0.1 when FreeSWITCH runs on the same VPS as the API server.
# ESL listens on 127.0.0.1 only (not exposed to internet).
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
# CHANGE THIS — never leave as the default ClueCon in production!
FREESWITCH_ESL_PASSWORD=change_me_to_a_strong_password

# Internal WebSocket URL for the Verto proxy (browser WebRTC ↔ FreeSWITCH).
# This is the INTERNAL URL the API server uses to proxy WS to FreeSWITCH.
# Always use 127.0.0.1 — never the public IP here.
FREESWITCH_WS_URL=ws://127.0.0.1:8081/

# Internal WebSocket URL for the SIP proxy (mobile JsSIP ↔ FreeSWITCH).
# Always use 127.0.0.1 — never the public IP here.
FREESWITCH_SIP_WS_URL=ws://127.0.0.1:5066
FREESWITCH_SIP_WS_PORT=5066

# SSH access to FreeSWITCH (used for config provisioning and voicemail SSH)
FREESWITCH_SSH_USER=root
FREESWITCH_SSH_PORT=22

# Private SSH key (PEM format) for connecting to the FreeSWITCH server.
# In .env, wrap in double quotes and use \n for newlines.
FREESWITCH_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END OPENSSH PRIVATE KEY-----\n"

# Path to FreeSWITCH config directory on the server
FREESWITCH_CONF_DIR=/etc/freeswitch

# Path where FreeSWITCH stores voicemail recordings
FREESWITCH_STORAGE_DIR=/usr/local/freeswitch/storage

# Secret token sent by FreeSWITCH in X-FreeSWITCH-Signature webhook header
FREESWITCH_WEBHOOK_SECRET=change_me_to_a_random_secret

# SIP trunk used for external mobile/PSTN calls.
# Without these values, internal extension calls can work but real phone numbers cannot be reached.
PSTN_GATEWAY_NAME=your-sip-trunk
PSTN_GATEWAY_USERNAME=your-sip-username
PSTN_GATEWAY_PASSWORD=your-sip-password
PSTN_GATEWAY_PROXY=sip.provider.example
PSTN_GATEWAY_REALM=sip.provider.example
PSTN_GATEWAY_FROM_DOMAIN=sip.provider.example
PSTN_GATEWAY_REGISTER=true

# ── PayFast (payments) ────────────────────────────────────────────────────────
# https://www.payfast.co.za → My Account → Settings → Merchant Details

PAYFAST_MERCHANT_ID=10000001
PAYFAST_MERCHANT_KEY=q1cd2rdny4a53
PAYFAST_PASSPHRASE=your_passphrase_here

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for verification emails and password resets

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="PRaww+ <noreply@praww.co.za>"

# ── Call limits & billing ─────────────────────────────────────────────────────

# Coins below this threshold triggers a low-balance notification
LOW_BALANCE_THRESHOLD_COINS=10

# Maximum billable seconds per individual call (safety cap)
MAX_BILLSEC_PER_CALL=3600

# Maximum coins a user can spend in a single day
MAX_COINS_SPEND_PER_DAY=500

# Maximum simultaneous active calls per user
MAX_CONCURRENT_CALLS_PER_USER=2

# Reconciliation job interval in milliseconds (default: 60000 = 1 minute)
RECONCILIATION_INTERVAL_MS=60000

# ── Optional overrides ────────────────────────────────────────────────────────

# Override static frontend directory (leave blank — api-server resolves it automatically)
# STATIC_DIR=/home/ubuntu/PRawwPlus/artifacts/prawwplus/dist/public

# Comma-separated CORS origins (leave blank to use APP_URL in production)
# ALLOWED_ORIGINS=https://rtc.praww.co.za,https://admin.praww.co.za

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# WebRTC ICE servers (JSON array — leave blank for default STUN only)
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:your.turn.server","username":"user","credential":"pass"}]
