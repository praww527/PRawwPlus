# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Build outputs ──────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/

# ── IDE / Editor ───────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── System Files ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log
yarn-error.log
pnpm-debug.log

# ── Secrets & environment ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# ── Replit platform files (never commit these to your VPS repo) ────────────────
.replit
.replitignore
replit.md
.cache/
.local/
.agents/
attached_assets/
.replit-artifact
**/.replit-artifact/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── Coverage ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
