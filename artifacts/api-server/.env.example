# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
# Set to "1" when behind a reverse proxy (Nginx, etc.)
TRUST_PROXY=1

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Session ──────────────────────────────────────────────────────────────────
# At least 32 random characters. Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ─── App URL (used for PayFast return URLs and email links) ───────────────────
APP_URL=https://your-domain.example

# ─── FreeSWITCH ───────────────────────────────────────────────────────────────
# Public domain / IP of your FreeSWITCH server (used in dialplan & Verto config)
FREESWITCH_DOMAIN=sip.example.com

# WebSocket URL served to Verto web clients (browser reachable)
FREESWITCH_WS_URL=wss://sip.example.com:8082

# Internal WebSocket URL used by the API server to reach FreeSWITCH
FREESWITCH_INTERNAL_WS_URL=ws://127.0.0.1:8081

# ESL (Event Socket Layer) connection — usually localhost on the FS box
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# SSH access so the API server can push generated XML to FreeSWITCH
FREESWITCH_SSH_USER=admin
# Private key (PEM, base64-encoded) for passwordless SSH to the FS box
FREESWITCH_SSH_KEY=

# ─── Firebase (FCM push notifications for mobile) ────────────────────────────
FIREBASE_PROJECT_ID=prawwplus-1324c
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@prawwplus-1324c.iam.gserviceaccount.com
# Newlines must be escaped as \n — wrap the whole value in double-quotes in .env
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── PayFast (payments) ───────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# ─── SMTP (transactional email) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_USER=no-reply@example.com
SMTP_PASS=
SMTP_FROM="PRawwPlus <no-reply@example.com>"

# ─── Optional / advanced ──────────────────────────────────────────────────────
# JSON array of STUN/TURN servers for Verto ICE, e.g.:
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
ICE_SERVERS=

# Require fsCallId on external call creation (set false for legacy SIP clients)
# REQUIRE_FS_CALL_ID_EXTERNAL=true

# Shared secret for FreeSWITCH webhook calls to /api/calls/webhook/freeswitch
# FREESWITCH_WEBHOOK_SECRET=
