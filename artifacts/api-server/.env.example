# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Set to "1" when behind nginx/reverse proxy (enables X-Forwarded-* trust)
TRUST_PROXY=1

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Session ──────────────────────────────────────────────────────────────────
# Min 32 random characters — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ─── App URL (return URLs for PayFast, email links) ───────────────────────────
APP_URL=https://rtc.praww.co.za

# ─── FreeSWITCH ───────────────────────────────────────────────────────────────
FREESWITCH_DOMAIN=sip.praww.co.za
FREESWITCH_WS_URL=wss://sip.praww.co.za:8082
FREESWITCH_INTERNAL_WS_URL=ws://127.0.0.1:8081
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
# Override ESL host if it differs from FREESWITCH_DOMAIN (optional)
# FREESWITCH_ESL_HOST=
FREESWITCH_SSH_USER=admin
FREESWITCH_SSH_PORT=22
FREESWITCH_CONF_DIR=/usr/local/freeswitch/conf
# SIP WebSocket port on the FreeSWITCH server (JsSIP/mobile uses this)
FREESWITCH_SIP_WS_PORT=5066
# Base64-encoded PEM private key for SSH to the FreeSWITCH box
FREESWITCH_SSH_KEY=

# Optional shared secret for FS → API webhooks
FREESWITCH_WEBHOOK_SECRET=

# ─── Firebase FCM (mobile push notifications) ────────────────────────────────
FIREBASE_PROJECT_ID=prawwplus-1324c
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@prawwplus-1324c.iam.gserviceaccount.com
# Escape newlines as \n and wrap the whole value in double quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── PayFast ──────────────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=
SMTP_FROM="PRawwPlus <no-reply@example.com>"

# ─── Optional / advanced ──────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
# JSON array of STUN/TURN servers, e.g.:
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
ICE_SERVERS=
